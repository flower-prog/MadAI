# 复制为 `.env` 后填写；OpenAI 和 Azure OpenAI 只需要配一套。

# OpenAI / OpenAI-compatible 的 API Key
OPENAI_API_KEY=

# OpenAI / OpenAI-compatible 的接口地址，官方默认是 https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# 默认模型名
OPENAI_MODEL=gpt-5.4

# 测试脚本接口风格：auto | responses | chat
OPENAI_TEST_API_STYLE=auto

# Azure OpenAI 的 endpoint，不用 Azure 就留空
AZURE_OPENAI_ENDPOINT=

# Azure OpenAI 的 API Key，不用 Azure 就留空
AZURE_OPENAI_API_KEY=

# Azure OpenAI 的 API 版本
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure endpoint 的兼容别名，通常留空即可
OPENAI_ENDPOINT=

# 临床工具主模型
CLINICAL_TOOL_AGENT_MODEL=gpt-5.4

# calculator 检索召回 top-k
MEDAI_RETRIEVAL_TOP_K=5

# 基础模型回退值
BASIC_MODEL=gpt-5.4

# 计算模型回退值
CODING_MODEL=gpt-5.4

# 推理模型别名，暂时不用可以留空
REASONING_MODEL=

# Planner 模型别名，暂时不用可以留空
PLANNER_MODEL=

# Tester 模型别名，暂时不用可以留空
TESTER_MODEL=

# BASIC 通道的 API Key，留空时默认复用 OPENAI_API_KEY
BASIC_API_KEY=

# CODING 通道的 API Key，留空时默认复用 OPENAI_API_KEY
CODING_API_KEY=

# BASIC 通道的 Base URL，留空时默认复用主接口地址
BASIC_BASE_URL=

# CODING 通道的 Base URL，留空时默认复用主接口地址
CODING_BASE_URL=

# DeepSeek streaming 开关，默认 false
DEEPSEEK_STREAMING=false
