# Copy this file to `.env` and fill in one provider path.

# OpenAI / OpenAI-compatible API key
OPENAI_API_KEY=

# OpenAI / OpenAI-compatible base URL. Official default:
# https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Default model name
OPENAI_MODEL=gpt-5.4

# Test script API style: auto | responses | chat
OPENAI_TEST_API_STYLE=auto

# Azure OpenAI endpoint. Leave empty if you are not using Azure.
AZURE_OPENAI_ENDPOINT=

# Azure OpenAI API key. Leave empty if you are not using Azure.
AZURE_OPENAI_API_KEY=

# Azure OpenAI API version
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Optional compatibility alias for Azure endpoint
OPENAI_ENDPOINT=

# Primary clinical tool model
CLINICAL_TOOL_AGENT_MODEL=gpt-5.4

# Retrieval recall top-k for calculator search
MEDAI_RETRIEVAL_TOP_K=5

# Trial retrieval defaults. These values are used by the protocol trial retriever
# when no CLI override is provided.
MEDAI_TRIAL_QDRANT_URL=http://127.0.0.1:6333
MEDAI_TRIAL_QDRANT_COLLECTION=trial_chunks_medcpt_full
MEDAI_TRIAL_QDRANT_API_KEY=
# Leave empty unless you intentionally want embedded/local Qdrant mode.
MEDAI_TRIAL_QDRANT_PATH=

# Protocol trial retrieval / eligibility assessment limits.
# coarse_top_k: number of trial IDs kept after full-corpus coarse recall.
# fine_top_k: number of trial-level candidates kept after chunk-level reranking.
# eligibility limit: number of top trial candidates that run full criteria assessment.
# Conservative online defaults: 300 / 20 / 5.
# Research/evaluation mode over a large corpus can use: 1000 / 50 / 10.
MEDAI_PROTOCOL_TRIAL_COARSE_TOP_K=300
MEDAI_PROTOCOL_TRIAL_TOP_K=20
MEDAI_PROTOCOL_ELIGIBILITY_LIMIT=5

# Workflow branch controls.
# Default: protocol_entry starts the direct protocol preflight branch and the
# clinical_assisstment -> calculator branch, then fans in to the final protocol
# aggregation path.
MEDAI_PROTOCOL_ASYNC_FANOUT=true
# Direct protocol only: skip clinical_assisstment/calculator.
MEDAI_PROTOCOL_DIRECT=false
MEDAI_SKIP_CLINICAL_ASSISSTMENT=false
MEDAI_SKIP_CLINICAL_ASSESSMENT=false
# Calculator only: run clinical_assisstment/calculator and skip protocol.
MEDAI_CALCULATOR_ONLY=false
MEDAI_SKIP_PROTOCOL=false

# Protocol internal subagent controls.
MEDAI_PROTOCOL_SKIP_TRIAL_AGENT=false
MEDAI_PROTOCOL_SKIP_MEDICAL_KNOWLEDGE_AGENT=false
MEDAI_PROTOCOL_SKIP_PATIENT_CALCULATOR_EVIDENCE_AGENT=false
MEDAI_PROTOCOL_SKIP_RISK_EVIDENCE_AGENT=false

# Fallback routing models
BASIC_MODEL=gpt-5.4
CODING_MODEL=gpt-5.4

# Optional aliases
REASONING_MODEL=
PLANNER_MODEL=
TESTER_MODEL=

# Channel-specific overrides. Leave empty to reuse OPENAI_API_KEY / OPENAI_BASE_URL.
BASIC_API_KEY=
CODING_API_KEY=
BASIC_BASE_URL=
CODING_BASE_URL=

# DeepSeek-compatible streaming flag
DEEPSEEK_STREAMING=false
