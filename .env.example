# Copy this file to `.env` and fill in one provider path.

# OpenAI / OpenAI-compatible API key
OPENAI_API_KEY=

# OpenAI / OpenAI-compatible base URL. Official default:
# https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Default model name
OPENAI_MODEL=gpt-5.4

# Test script API style: auto | responses | chat
OPENAI_TEST_API_STYLE=auto

# Azure OpenAI endpoint. Leave empty if you are not using Azure.
AZURE_OPENAI_ENDPOINT=

# Azure OpenAI API key. Leave empty if you are not using Azure.
AZURE_OPENAI_API_KEY=

# Azure OpenAI API version
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Optional compatibility alias for Azure endpoint
OPENAI_ENDPOINT=

# Primary clinical tool model
CLINICAL_TOOL_AGENT_MODEL=gpt-5.4

# Retrieval recall top-k for calculator search
MEDAI_RETRIEVAL_TOP_K=5

# Fallback routing models
BASIC_MODEL=gpt-5.4
CODING_MODEL=gpt-5.4

# Optional aliases
REASONING_MODEL=
PLANNER_MODEL=
TESTER_MODEL=

# Channel-specific overrides. Leave empty to reuse OPENAI_API_KEY / OPENAI_BASE_URL.
BASIC_API_KEY=
CODING_API_KEY=
BASIC_BASE_URL=
CODING_BASE_URL=

# DeepSeek-compatible streaming flag
DEEPSEEK_STREAMING=false
